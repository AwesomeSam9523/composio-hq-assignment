# Required: the LLM that reasons over search results and writes each row.
# Google AI Studio key (free tier works): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required: Composio serves the agent's search/fetch tools — the no-auth
# COMPOSIO_SEARCH toolkit (web search, Tavily, news, URL-content fetch).
# Free key from https://app.composio.dev
COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=buildability-research

# Optional overrides
# RESEARCH_MODEL=gemini-2.5-flash   # e.g. gemini-2.5-pro on a paid key
# MAX_TOOL_TURNS=12                 # max tool-use turns per app
# COMPOSIO_USER_ID=buildability-research

# The batch pipeline (pipeline/research_agent.py) and the live Streamlit app
# share the same engine and the same two keys above — nothing else is needed.
